<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Platform Dashboard</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;600&family=Syne:wght@700;800&display=swap');
:root {
  --bg:#111318;--surface:#1a1d26;--border:#252836;
  --green:#3dd68c;--blue:#4d9cf6;--amber:#f5a623;--red:#f25757;
  --muted:#6b7590;--text:#dde3f0;--text2:#a0aab8;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'JetBrains Mono',monospace;background:var(--bg);color:var(--text);padding:20px;font-size:13px;line-height:1.5;}
.header{display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;}
.logo{font-family:'Syne',sans-serif;font-size:18px;font-weight:800;}
.logo em{color:var(--green);font-style:normal;}
.live-dot{width:6px;height:6px;border-radius:50%;background:var(--green);animation:blink 2s infinite;display:inline-block;margin-right:6px;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0.3}}
.refresh-btn{background:transparent;border:1px solid var(--border);color:var(--text2);font-family:'JetBrains Mono',monospace;font-size:11px;padding:5px 12px;border-radius:4px;cursor:pointer;}
.refresh-btn:hover{border-color:var(--green);color:var(--green);}
.status-bar{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:16px;}
.stat{background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:14px 16px;}
.stat-label{font-size:10px;color:var(--muted);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:6px;}
.stat-val{font-family:'Syne',sans-serif;font-size:24px;font-weight:800;line-height:1;}
.stat-sub{font-size:11px;color:var(--text2);margin-top:4px;}
.green{color:var(--green);}.red{color:var(--red);}.amber{color:var(--amber);}.blue{color:var(--blue);}
.card{background:var(--surface);border:1px solid var(--border);border-radius:6px;margin-bottom:16px;overflow:hidden;}
.card-header{display:flex;justify-content:space-between;align-items:center;padding:12px 16px;cursor:pointer;}
.card-header:hover{background:rgba(255,255,255,0.02);}
.card-title{font-size:10px;letter-spacing:1.5px;text-transform:uppercase;}
.card-title.blue{color:var(--blue);}
.card-title.amber{color:var(--amber);}
.card-title.muted{color:var(--text2);}
.card-body{border-top:1px solid var(--border);padding:16px;}
.card-body.hidden{display:none;}
.chevron{font-size:10px;color:var(--muted);transition:transform 0.2s;}
.chevron.open{transform:rotate(180deg);}
.badge{font-size:10px;padding:2px 7px;border-radius:3px;font-weight:600;}
.badge-green{background:rgba(61,214,140,0.1);color:var(--green);}
.badge-amber{background:rgba(245,166,35,0.1);color:var(--amber);}
.badge-red{background:rgba(242,87,87,0.1);color:var(--red);}
.badge-gray{background:rgba(74,80,104,0.2);color:var(--muted);}
.badge-blue{background:rgba(77,156,246,0.1);color:var(--blue);}
.report-text{font-size:12px;color:var(--text);line-height:1.8;white-space:pre-wrap;}
.intel-item{padding:12px 0;border-bottom:1px solid var(--border);}
.intel-item:last-child{border-bottom:none;}
.intel-row{display:flex;align-items:center;gap:8px;margin-bottom:6px;flex-wrap:wrap;}
.intel-sha{color:var(--blue);font-size:11px;}
.intel-msg{font-size:12px;color:var(--text);margin-bottom:4px;}
.intel-detail{font-size:12px;color:var(--text2);line-height:1.6;margin-bottom:6px;}
.intel-emp{font-size:11px;color:var(--blue);}
.explain-btn{background:rgba(77,156,246,0.08);border:1px solid rgba(77,156,246,0.2);color:var(--blue);font-family:'JetBrains Mono',monospace;font-size:11px;padding:4px 12px;border-radius:3px;cursor:pointer;margin-top:6px;}
.explain-btn:hover{background:rgba(77,156,246,0.15);}
.explain-box{margin-top:8px;padding:12px;background:rgba(0,0,0,0.3);border-radius:4px;font-size:12px;color:var(--text);line-height:1.7;white-space:pre-wrap;}
.close-btn{float:right;background:none;border:none;color:var(--muted);cursor:pointer;font-size:14px;padding:0 4px;}
.pod-row{display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid rgba(30,33,48,0.6);}
.pod-row:last-child{border-bottom:none;}
.dot{width:6px;height:6px;border-radius:50%;display:inline-block;margin-right:6px;}
.dot-g{background:var(--green);}.dot-r{background:var(--red);}.dot-a{background:var(--amber);}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;}
.log-filters{display:flex;gap:6px;}
.filter{background:transparent;border:1px solid var(--border);color:var(--muted);font-family:'JetBrains Mono',monospace;font-size:10px;padding:3px 9px;border-radius:3px;cursor:pointer;}
.filter.active{border-color:var(--green);color:var(--green);background:rgba(61,214,140,0.06);}
.log-body{max-height:320px;overflow-y:auto;padding:12px 16px;}
.log-entry{display:flex;gap:12px;padding:3px 0;border-bottom:1px solid rgba(30,33,48,0.4);font-size:11px;}
.log-entry:last-child{border-bottom:none;}
.log-t{color:var(--muted);flex-shrink:0;}
.log-ok{color:var(--green);}.log-err{color:var(--red);}.log-warn{color:var(--amber);}.log-info{color:var(--blue);}.log-dim{color:var(--text2);}
</style>
</head>
<body>

<div class="header">
  <div class="logo"><em>⬡</em> Platform<em>.</em>OS</div>
  <div style="display:flex;align-items:center;gap:12px;">
    <span class="live-dot"></span>
    <span style="font-size:11px;color:var(--muted)">refresh in <span id="cd">30</span>s</span>
    <!-- FIX: Refresh Button resettet jetzt auch den Countdown -->
    <button class="refresh-btn" onclick="manualRefresh()">↻ Refresh</button>
  </div>
</div>

<div class="status-bar">
  <div class="stat"><div class="stat-label">LLM Server</div><div class="stat-val" id="s-llama">—</div><div class="stat-sub" id="s-llama-sub">—</div></div>
  <div class="stat"><div class="stat-label">RAM frei</div><div class="stat-val" id="s-ram">—</div><div class="stat-sub">von 64 GB</div></div>
  <div class="stat"><div class="stat-label">Letzter Run</div><div class="stat-val" id="s-run" style="font-size:16px;margin-top:4px">—</div><div class="stat-sub" id="s-run-sub">—</div></div>
  <div class="stat"><div class="stat-label">Aktionen</div><div class="stat-val" id="s-actions">—</div><div class="stat-sub">heute</div></div>
</div>

<!-- Wochenbericht -->
<div class="card" id="report-card" style="display:none">
  <div class="card-header" onclick="toggle('report-body','report-chev')">
    <span class="card-title blue">Wochenbericht</span>
    <div style="display:flex;align-items:center;gap:8px;">
      <span id="report-date" style="font-size:11px;color:var(--muted)"></span>
      <span class="chevron open" id="report-chev">▼</span>
    </div>
  </div>
  <div class="card-body" id="report-body">
    <div class="report-text" id="report-text"></div>
  </div>
</div>

<!-- TurboQuant Intelligence -->
<div class="card" id="intel-card" style="display:none">
  <div class="card-header" onclick="toggle('intel-body','intel-chev')">
    <span class="card-title amber">TurboQuant Intelligence</span>
    <div style="display:flex;align-items:center;gap:8px;">
      <span id="intel-count" class="badge badge-amber"></span>
      <span class="chevron open" id="intel-chev">▼</span>
    </div>
  </div>
  <div class="card-body" id="intel-body">
    <div id="intel-list"></div>
  </div>
</div>

<!-- K8s + System -->
<div class="grid2">
  <div class="card">
    <div class="card-header" onclick="toggle('pods-body','pods-chev')">
      <span class="card-title muted">Kubernetes Pods</span>
      <div style="display:flex;align-items:center;gap:8px;">
        <span id="pods-badge" class="badge badge-green"></span>
        <span class="chevron" id="pods-chev">▼</span>
      </div>
    </div>
    <div class="card-body hidden" id="pods-body"><div id="pods-list"></div></div>
  </div>
  <div class="card">
    <div class="card-header" onclick="toggle('sys-body','sys-chev')">
      <span class="card-title muted">System Health</span>
      <div style="display:flex;align-items:center;gap:8px;">
        <span id="sys-badge" class="badge badge-green">OK</span>
        <span class="chevron" id="sys-chev">▼</span>
      </div>
    </div>
    <div class="card-body hidden" id="sys-body"><div id="sys-list"></div></div>
  </div>
</div>

<!-- Log Viewer -->
<div class="card">
  <div class="card-header" style="cursor:default;">
    <span class="card-title muted">Agent Log</span>
    <div class="log-filters">
      <button class="filter active" onclick="setFilter('all',this)">ALL</button>
      <button class="filter" onclick="setFilter('ok',this)">OK</button>
      <button class="filter" onclick="setFilter('warn',this)">WARN</button>
      <button class="filter" onclick="setFilter('err',this)">ERR</button>
      <button class="filter" onclick="setFilter('info',this)">INFO</button>
    </div>
  </div>
  <div class="log-body" id="log-body"></div>
</div>

<script>
let logs=[], filter='all', intelData=[], weeklyReport=null;

// FIX: Speichert geladene Explain-Inhalte zwischen Refreshes
// Key: sha, Value: { html: string, visible: boolean }
const explainCache = {};

function toggle(bodyId, chevId) {
  const b = document.getElementById(bodyId);
  const c = document.getElementById(chevId);
  const isHidden = b.classList.contains('hidden') || b.style.display === 'none';
  if(isHidden) { b.classList.remove('hidden'); b.style.display=''; c.classList.add('open'); }
  else { b.classList.add('hidden'); c.classList.remove('open'); }
}

function setFilter(f,btn) {
  filter=f;
  document.querySelectorAll('.filter').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  renderLogs();
}

function classify(line) {
  if(line.includes('✅')) return 'ok';
  if(line.includes('❌')||line.includes('🚨')||line.includes('Killed')) return 'err';
  if(line.includes('⚠️')||line.includes('down')||line.includes('nötig')) return 'warn';
  if(line.includes('🔬')||line.includes('TurboQuant')||line.includes('WOCHENBERICHT')) return 'info';
  return 'dim';
}

function parseTime(line) {
  const m = line.match(/\[(\d{2}:\d{2}:\d{2})\]/)||line.match(/(\d{2}:\d{2}:\d{2}) CEST/);
  return m?m[1]:'';
}

function renderLogs() {
  const body = document.getElementById('log-body');
  const filtered = filter==='all' ? logs : logs.filter(l=>classify(l)===filter);
  if(!filtered.length){body.innerHTML='<div class="log-entry"><span class="log-dim">Keine Einträge.</span></div>';return;}
  body.innerHTML = filtered.slice(-100).reverse().map(line=>{
    const cls=classify(line);
    const t=parseTime(line);
    const msg=line.replace(/\[\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\]\s*/,'').replace(/\[.+?\d{2}:\d{2}:\d{2} CEST \d{4}\]\s*/,'').trim();
    return `<div class="log-entry"><span class="log-t">${t}</span><span class="log-${cls==='dim'?'dim':cls}">${msg}</span></div>`;
  }).join('');
}

function renderIntel() {
  if(!intelData.length) return;
  document.getElementById('intel-card').style.display='block';
  const relevantCount = intelData.filter(a=>a.relevant).length;
  document.getElementById('intel-count').textContent = relevantCount+' relevant';

  const notRelevant = intelData.filter(a=>!a.relevant);
  if(notRelevant.length) {
    let extraCard = document.getElementById('non-relevant-card');
    if(!extraCard) {
      extraCard = document.createElement('div');
      extraCard.id = 'non-relevant-card';
      extraCard.className = 'card';
      extraCard.style = 'margin-bottom:16px';
      document.getElementById('intel-card').after(extraCard);
    }
    extraCard.innerHTML = `
      <div class="card-header" onclick="toggle('non-rel-body','non-rel-chev')">
        <span class="card-title muted">Weitere Commits</span>
        <div style="display:flex;align-items:center;gap:8px">
          <span class="badge badge-gray">${notRelevant.length} nicht relevant</span>
          <span class="chevron" id="non-rel-chev">▼</span>
        </div>
      </div>
      <div class="card-body hidden" id="non-rel-body">
        ${notRelevant.map(a=>{
          const sha=a.short_sha||(a.sha||'').substring(0,7);
          return '<div class="intel-item" style="opacity:0.6"><div class="intel-row"><span class="intel-sha">['+sha+']</span><span class="badge badge-gray">'+a.category+'</span><span style="font-size:10px;color:var(--muted)">'+((a.repo||'').split('/')[1]||'')+'</span></div><div class="intel-msg">'+a.message+'</div></div>';
        }).join('')}
      </div>`;
  }

  // FIX: Vor dem Neu-Rendern aktuellen Explain-State sichern
  intelData.filter(a=>a.relevant).forEach(a => {
    const sha = a.short_sha || (a.sha||'').substring(0,7);
    const box = document.getElementById('ex-'+sha);
    if(box && box.dataset.loaded === '1') {
      explainCache[sha] = { html: box.innerHTML, visible: box.style.display !== 'none' };
    }
  });

  document.getElementById('intel-list').innerHTML = intelData.filter(a=>a.relevant).map(a=>{
    const sha = a.short_sha || (a.sha||'').substring(0,7);
    const risk = a.risiko||'';
    const badgeCls = risk==='hoch'?'badge-red':risk==='mittel'?'badge-amber':'badge-green';
    const relBadge = a.relevant ? '' : '<span class="badge badge-gray">nicht relevant</span>';
    const compiled = window.compiledSha||'';
    const isCompiled = compiled && sha.startsWith(compiled.slice(0,6));
    const compiledBadge = isCompiled
      ? `<div style="margin-top:6px"><span class="badge badge-green">✅ kompiliert · ${compiled}</span></div>`
      : (a.relevant ? '<div style="margin-top:6px"><span class="badge badge-amber">⏳ ausstehend</span></div>' : '');

    // FIX: Cached explain-box wiederherstellen wenn vorhanden
    const cached = explainCache[sha];
    const explainDisplay = cached && cached.visible ? 'block' : 'none';
    const explainContent = cached ? cached.html : '';
    const explainLoaded = cached ? '1' : '';

    return `<div class="intel-item">
      <div class="intel-row">
        <a class="intel-sha" href="https://github.com/TheTom/llama-cpp-turboquant/commit/${sha}" target="_blank" style="text-decoration:none;color:var(--blue)">[${sha}] ↗</a>
        <span class="badge ${badgeCls}">${a.category||'—'}</span>
        ${relBadge}
      </div>
      <div style="font-size:10px;color:var(--muted);margin-bottom:4px">${(a.date||'').slice(0,10)} ${(a.date||'').slice(11,16)} · ${a.repo||''}</div>
      <div class="intel-msg">${a.message||''}</div>
      ${a.auswirkung?`<div class="intel-detail">→ ${a.auswirkung}</div>`:''}
      ${a.empfehlung?`<div class="intel-emp">Empfehlung: ${a.empfehlung}</div>`:''}
      ${compiledBadge}
      <button class="explain-btn" data-sha="${sha}" data-msg="${(a.message||'').replace(/"/g,'&quot;')}" data-cat="${a.category||''}" data-awk="${(a.auswirkung||'').replace(/"/g,'&quot;')}" onclick="explain(this)">→ Wie kompiliere ich das?</button>
      <div class="explain-box" id="ex-${sha}" style="display:${explainDisplay}" data-loaded="${explainLoaded}">${explainContent}</div>
    </div>`;
  }).join('');
}

async function explain(btn) {
  const sha=btn.dataset.sha, msg=btn.dataset.msg, cat=btn.dataset.cat, awk=btn.dataset.awk;
  const box=document.getElementById('ex-'+sha);

  // FIX: Toggle wenn bereits geladen (auch nach Refresh)
  if(box.dataset.loaded==='1'){
    box.style.display = box.style.display==='none' ? 'block' : 'none';
    // Cache sichtbarkeit updaten
    if(explainCache[sha]) explainCache[sha].visible = box.style.display !== 'none';
    return;
  }

  box.style.display='block';
  box.innerHTML='<span style="color:var(--text2)">⏳ Frage LLM...</span>';

  try {
    const r=await fetch('/llm',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        model:'local',max_tokens:600,
        messages:[{role:'user',content:`Ich habe MacBook Pro M5 Pro 64GB. TheTom/llama-cpp-turboquant Fork, turbo4 KV-Cache, Apple Metal/Clang.\n\nCommit [${sha}]: ${msg}\nKategorie: ${cat}\nAuswirkung: ${awk}\n\nErkläre auf Deutsch:\n1. Was ändert sich für mein Setup?\n2. Exakte Befehle zum Neu-Kompilieren\n3. Was testen danach?`}]
      })
    });
    const d=await r.json();
    const text=d.choices?.[0]?.message?.content||'Keine Antwort';
    const html=`<button class="close-btn" onclick="closeExplain('${sha}')">✕</button>${text.replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\n/g,'<br>')}`;
    box.dataset.loaded='1';
    box.innerHTML=html;
    // FIX: In Cache speichern
    explainCache[sha] = { html: html, visible: true };
  } catch(e) {
    const html=`<button class="close-btn" onclick="closeExplain('${sha}')">✕</button>LLM nicht erreichbar — starte ai-llama-fast`;
    box.innerHTML=html;
    // Nicht als loaded markieren damit Retry möglich
  }
}

// FIX: Separater Close-Handler der Cache updated
function closeExplain(sha) {
  const box = document.getElementById('ex-'+sha);
  if(box) box.style.display='none';
  if(explainCache[sha]) explainCache[sha].visible = false;
}

function updateStats() {
  const llamaOk=logs.some(l=>l.includes('llama-server läuft'));
  const llamaDown=logs.some(l=>l.includes('llama-server down')||l.includes('nicht erreichbar'));
  const el=document.getElementById('s-llama');
  if(llamaOk){el.textContent='RUNNING';el.className='stat-val green';document.getElementById('s-llama-sub').textContent='Port 8080';}
  else if(llamaDown){el.textContent='DOWN';el.className='stat-val red';document.getElementById('s-llama-sub').textContent='Incident Agent aktiv';}
  else{el.textContent='?';el.className='stat-val amber';}

  const ramLine=logs.filter(l=>l.includes('RAM frei:')).pop();
  if(ramLine){const m=ramLine.match(/RAM frei:\s*([\d.]+)/);if(m){const el2=document.getElementById('s-ram');el2.textContent=m[1]+' GB';el2.className='stat-val '+(parseFloat(m[1])<5?'red':'green');}}

  const lastEnd=logs.filter(l=>l.includes('Platform Agent v3 beendet')).pop();
  if(lastEnd){const m=lastEnd.match(/\[(\d{4}-\d{2}-\d{2} (\d{2}:\d{2}:\d{2}))\]/);if(m){document.getElementById('s-run').textContent=m[2];document.getElementById('s-run').className='stat-val blue';document.getElementById('s-run-sub').textContent=m[1].split(' ')[0];}}

  const actions=logs.filter(l=>l.includes('→ ')&&!l.includes('Empfehlung')&&!l.includes('Auswirkung')).length;
  const el3=document.getElementById('s-actions');el3.textContent=actions;el3.className='stat-val '+(actions>0?'amber':'green');

  const podLines=logs.filter(l=>l.includes('ollama-app')&&l.includes('Running'));
  document.getElementById('pods-badge').textContent=podLines.length+' running';
  document.getElementById('pods-list').innerHTML=podLines.map(l=>{
    const name=(l.match(/ollama-app[\w-]+/)||['?'])[0].replace('ollama-app-','');
    const r=parseInt((l.match(/restarts: (\d+)/)||[0,0])[1]);
    return `<div class="pod-row"><span><span class="dot ${r>5?'dot-a':'dot-g'}"></span>${name}</span><span class="badge ${r>5?'badge-amber':'badge-green'}">${r} restarts</span></div>`;
  }).join('');

  const disk=logs.filter(l=>l.includes('Frei:')&&l.includes('Modelle:')).pop();
  const gpu=logs.filter(l=>l.includes('GPU Memory Limit')).pop();
  let sysHtml='';
  if(disk){const m=disk.match(/Frei: (\d+) GB \| Modelle: (\d+) GB/);if(m)sysHtml+=`<div class="pod-row"><span>Disk frei</span><span class="badge badge-green">${m[1]} GB</span></div><div class="pod-row"><span>Modelle</span><span class="badge badge-gray">${m[2]} GB</span></div>`;}
  if(gpu){const ok=gpu.includes('✅');sysHtml+=`<div class="pod-row"><span>GPU Limit</span><span class="badge ${ok?'badge-green':'badge-red'}">${ok?'52429 MB':'nicht gesetzt'}</span></div>`;}
  document.getElementById('sys-list').innerHTML=sysHtml||'<div class="pod-row"><span class="log-dim">Keine Daten</span></div>';
}

function renderWeekly() {
  if(!weeklyReport) return;
  document.getElementById('report-card').style.display='block';
  document.getElementById('report-text').textContent=weeklyReport.report||weeklyReport;
  document.getElementById('report-date').textContent=(weeklyReport.date||'').substring(0,10);
}

async function loadState() {
  try {
    const r = await fetch('/agent_state.json?t='+Date.now());
    if(r.ok) {
      const d = await r.json();
      window.compiledSha = d.compiled_sha || '';
      window.compiledCommits = d.compiled_commits || [];
    }
  } catch(e) {}
}

async function load() {
  await loadState();
  try {
    const r=await fetch('/logs/agent.log?t='+Date.now());
    if(r.ok){logs=(await r.text()).split('\n').filter(l=>l.trim());updateStats();renderLogs();}
  } catch(e){showDemo();}
  try {
    const r2=await fetch('/intelligence.json?t='+Date.now());
    if(r2.ok){const d=await r2.json();intelData=d.analyses||[];weeklyReport=(d.weekly_reports||[])[0]||null;renderIntel();renderWeekly();}
  } catch(e){}
}

// FIX: Manueller Refresh resettet Countdown
function manualRefresh() {
  cd = 30;
  const el = document.getElementById('cd');
  if(el) el.textContent = cd;
  load();
}

function showDemo(){
  const n=new Date().toISOString().slice(0,19).replace('T',' ');
  logs=[`[${n}] 🤖 Platform Agent v3 gestartet`,`[${n}]   ✅ llama-server läuft auf Port 8080`,`[${n}]   ✅ ollama-app-ollama: Running (restarts: 0)`,`[${n}]   ✅ ollama-app-open-webui: Running (restarts: 2)`,`[${n}]   RAM frei: 28.0 GB`,`[${n}]   💾 Frei: 595 GB | Modelle: 106 GB`,`[${n}]   🔬 TurboQuant neuer Commit: [883bf4a]`,`[${n}] 🤖 Platform Agent v3 beendet`];
  intelData=[{short_sha:'883bf4a',message:'Update GGMLQuantizationType and LlamaFileType enums to include TQ3_1S and TQ4_1S quantization types',category:'Feature',relevant:true,auswirkung:'Neue Quantisierungstypen TQ3_1S und TQ4_1S werden unterstützt. Dies ermöglicht Weight Compression für Modelle wie Llama 3.3 70B direkt im Fork.',empfehlung:'Beim nächsten Update neu kompilieren und testen',risiko:'niedrig'}];
  weeklyReport={date:n,report:'Demo-Modus aktiv.\n\nStarte den Log-Server mit:\ncd ~/mac-setup/agent && python3 -m http.server 8999\n\nDann http://localhost:8999/dashboard.html öffnen.'};
  updateStats();renderLogs();renderIntel();renderWeekly();
}

let cd=30;
setInterval(()=>{
  cd--;
  const e=document.getElementById('cd');
  if(e) e.textContent=cd;
  if(cd<=0){cd=30;load();}
},1000);
load();
</script>
</body>
