import requests
import json
import subprocess

def mempalace_search(query: str) -> str:
    try:
        r = subprocess.run(
            ["mempalace", "search", query, "--limit", "2"],
            capture_output=True, text=True, timeout=10
        )
        lines = [l for l in r.stdout.splitlines() if l.strip() and not l.startswith('=') and not l.startswith('-') and not l.startswith('[') and not l.startswith('Source') and not l.startswith('Match')]
        return "\n".join(lines[:5]) if lines else ""
    except:
        return ""
import re
from datetime import datetime, timedelta
from pathlib import Path
from typing import TypedDict
from langgraph.graph import StateGraph, END
from langchain_openai import ChatOpenAI

# ── Konfiguration ──────────────────────────────────────────────
LLAMA_SERVER  = "http://localhost:8080/v1"
LOG_FILE      = Path.home() / "mac-setup/agent/agent.log"
STATE_FILE    = Path.home() / "mac-setup/agent/agent_state.json"
INTEL_FILE    = Path.home() / "mac-setup/agent/intelligence.json"
CONTEXT_FILE  = Path.home() / "mac-setup/agent/SYSTEM_CONTEXT.md"

def load_context() -> str:
    if CONTEXT_FILE.exists():
        return CONTEXT_FILE.read_text()
    return ""

# ── State ──────────────────────────────────────────────────────
class IntelState(TypedDict):
    commits: list           # neue Commits
    prs: list               # neue PRs
    analyses: list          # LLM Analysen
    weekly_report: str      # Wochenbericht
    notifications: list     # was wird geloggt

# ── LLM ───────────────────────────────────────────────────────
def get_llm():
    try:
        requests.get("http://localhost:8080/health", timeout=3)
        return ChatOpenAI(
            base_url=LLAMA_SERVER,
            api_key="dummy",
            model="llama33-70b-q4km.gguf",
            temperature=0
        )
    except:
        return ChatOpenAI(
            base_url="http://localhost:8082/v1",
            api_key="dummy",
            model="llama31-8b-draft.gguf",
            temperature=0
        )

# ── Hilfsfunktionen ────────────────────────────────────────────
def log(message: str):
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    line = f"[{timestamp}] {message}"
    print(line)
    with open(LOG_FILE, "a") as f:
        f.write(line + "\n")

def load_state() -> dict:
    if STATE_FILE.exists():
        try:
            return json.loads(STATE_FILE.read_text())
        except:
            pass
    return {"llama_restarts": [], "seen_commits": [], "seen_models": {}, "metrics": []}

def save_state(state: dict):
    STATE_FILE.write_text(json.dumps(state, indent=2))

def load_intel() -> dict:
    if INTEL_FILE.exists():
        try:
            return json.loads(INTEL_FILE.read_text())
        except:
            pass
    return {"analyses": [], "weekly_reports": [], "last_weekly": ""}

def save_intel(intel: dict):
    INTEL_FILE.write_text(json.dumps(intel, indent=2))

def get_github_commits(repo: str, branch: str = "feature/turboquant-kv-cache", count: int = 5):
    try:
        url = f"https://api.github.com/repos/{repo}/commits?sha={branch}&per_page={count}"
        r = requests.get(url, timeout=10)
        if r.status_code == 200:
            return r.json()
    except Exception as e:
        log(f"  GitHub Fehler: {e}")
    return []

def get_pr_details(repo: str, pr_number: int):
    try:
        url = f"https://api.github.com/repos/{repo}/pulls/{pr_number}"
        r = requests.get(url, timeout=10)
        if r.status_code == 200:
            return r.json()
    except:
        pass
    return None

def get_release_notes(repo: str, version: str):
    try:
        url = f"https://api.github.com/repos/{repo}/releases/tags/v{version}"
        r = requests.get(url, timeout=10)
        if r.status_code == 200:
            return r.json().get("body", "")
    except:
        pass
    return ""

def get_llama_metrics():
    try:
        r = requests.get("http://localhost:8080/metrics", timeout=5)
        if r.status_code == 200:
            metrics = {}
            for line in r.text.split("\n"):
                if "llamacpp:tokens_per_second" in line and not line.startswith("#"):
                    match = re.search(r"(\d+\.?\d*)", line)
                    if match:
                        metrics["tokens_per_second"] = float(match.group(1))
                if "llamacpp:prompt_tokens_total" in line and not line.startswith("#"):
                    match = re.search(r"(\d+)", line)
                    if match:
                        metrics["total_tokens"] = int(match.group(1))
            return metrics
    except:
        pass
    return {}

# ── Node 1: Neue Commits analysieren ──────────────────────────
def analyze_commits(state: IntelState) -> IntelState:
    log("🔬 Intelligence: Analysiere neue Commits...")
    persistent = load_state()
    intel = load_intel()
    seen = set(persistent.get("seen_commits", []))

    # Alle beobachteten Repos
    watched_repos = [
        ("TheTom/llama-cpp-turboquant", "feature/turboquant-kv-cache"),
        ("milla-jovovich/mempalace", "main"),
        ("SharpAI/SwiftLM", "main"),
        ("arozanov/turboquant-mlx", "main"),
    ]
    
    all_commits = []
    for repo, branch in watched_repos:
        repo_commits = get_github_commits(repo, branch, count=3)
        for c in repo_commits:
            c["_repo"] = repo
        all_commits.extend(repo_commits)
    
    commits = all_commits
    new_commits = []

    for commit in commits:
        sha = commit["sha"][:7]
        if sha not in seen:
            msg = commit["commit"]["message"].split("\n")[0]
            new_commits.append({
                "sha": sha,
                "message": msg,
                "full_sha": commit["sha"],
                "date": commit["commit"]["author"]["date"],
                "url": commit["html_url"]
            })

    if not new_commits:
        log("  ✅ Keine neuen Commits")
        state["commits"] = []
        return state

    log(f"  🆕 {len(new_commits)} neue Commits gefunden")
    state["commits"] = new_commits

    # Jeden Commit mit LLM analysieren
    llm = get_llm()
    analyses = []

    for commit in new_commits:
        log(f"  🤔 Analysiere: [{commit['sha']}] {commit['message'][:50]}...")

        # PR Nummer aus Commit Message extrahieren
        pr_match = re.search(r"#(\d+)", commit["message"])
        pr_details = ""
        if pr_match:
            pr = get_pr_details("TheTom/llama-cpp-turboquant", int(pr_match.group(1)))
            if pr and pr.get("body"):
                pr_details = f"\nPR Beschreibung: {pr['body'][:500]}"

        system_ctx = load_context()
        # Relevante Entscheidungen aus MemPalace laden
        mem_context = mempalace_search(commit["message"][:50])
        
        prompt = f"""Du bist ein Platform Engineer der TurboQuant KV-Cache Änderungen bewertet.

MEIN SYSTEM:
{system_ctx}

FRÜHERE ENTSCHEIDUNGEN (aus Platform-Wissensbasis):
{mem_context}

Neuer Commit in TheTom/llama-cpp-turboquant:
SHA: {commit['sha']}
Nachricht: {commit['message']}{pr_details}

Beantworte folgende Fragen präzise:

1. KATEGORIE: [Performance / Bugfix / Feature / Docs / Infra]
2. RELEVANT: Ist das relevant für Llama 3.3 70B Q4_K_M auf Apple Silicon M5 Pro?
3. AUSWIRKUNG: Was ändert sich konkret? (1-2 Sätze)
4. EMPFEHLUNG: [Sofort neu kompilieren / Beim nächsten Update / Kein Handlungsbedarf]
5. RISIKO: [niedrig / mittel / hoch]
6. KOMPILIERBAR: Ist dieser Commit mit "cmake --build" auf dem llama.cpp Fork kompilierbar?
   NUR ja wenn Repo = TheTom/llama-cpp-turboquant
   MLX Repos (arozanov, helgklaizar, rachittshah, SharpAI/SwiftLM) = NEIN, anderer Stack

Antworte in diesem Format:
KATEGORIE: ...
RELEVANT: ja/nein
AUSWIRKUNG: ...
EMPFEHLUNG: ...
RISIKO: ...
KOMPILIERBAR: ja/nein"""

        try:
            response = llm.invoke(prompt)
            analysis_text = response.content.strip()

            category = re.search(r"KATEGORIE:\s*(.+)", analysis_text)
            relevant = re.search(r"RELEVANT:\s*(ja|nein)", analysis_text, re.I)
            auswirkung = re.search(r"AUSWIRKUNG:\s*(.+)", analysis_text)
            empfehlung = re.search(r"EMPFEHLUNG:\s*(.+)", analysis_text)
            risiko = re.search(r"RISIKO:\s*(niedrig|mittel|hoch)", analysis_text, re.I)
            kompilierbar = re.search(r"KOMPILIERBAR:\s*(ja|nein)", analysis_text, re.I)

            analysis = {
                "sha": commit["sha"],
                "short_sha": commit["sha"][:7],
                "repo": commit.get("repo", "TheTom/llama-cpp-turboquant"),
                "message": commit["message"],
                "date": commit["date"],
                "category": category.group(1).strip() if category else "Unbekannt",
                "relevant": relevant.group(1).lower() == "ja" if relevant else False,
                "auswirkung": auswirkung.group(1).strip() if auswirkung else "",
                "empfehlung": empfehlung.group(1).strip() if empfehlung else "",
                "risiko": risiko.group(1).lower() if risiko else "unbekannt",
                "kompilierbar": (kompilierbar.group(1).lower() == "ja") if kompilierbar else False,
                "analyzed_at": datetime.now().isoformat()
            }

            analyses.append(analysis)
            intel["analyses"].insert(0, analysis)

            # Notification erstellen
            emoji = "🔴" if analysis["risiko"] == "hoch" else "🟡" if analysis["risiko"] == "mittel" else "🟢"
            if analysis["relevant"]:
                notification = f"{emoji} TurboQuant [{commit['sha'][:7]}] {analysis['category']}: {analysis['auswirkung'][:80]} → {analysis['empfehlung']}"
                state["notifications"].append(notification)
                log(f"  {notification}")
            else:
                log(f"  ℹ️ [{commit['sha'][:7]}] nicht relevant für dein Setup")

            seen.add(commit["sha"][:7])

        except Exception as e:
            log(f"  ❌ Analyse Fehler: {e}")

    state["analyses"] = analyses

    # State aktualisieren
    persistent["seen_commits"] = list(seen)[-50:]
    save_state(persistent)

    intel["analyses"] = intel["analyses"][:100]
    save_intel(intel)

    return state

# ── Node 2: Metriken tracken ───────────────────────────────────
def track_metrics(state: IntelState) -> IntelState:
    log("📊 Intelligence: Tracke Performance-Metriken...")
    persistent = load_state()

    metrics = get_llama_metrics()
    metrics["timestamp"] = datetime.now().isoformat()
    metrics["ram_free_gb"] = None

    # RAM messen
    try:
        import subprocess
        r = subprocess.run(["vm_stat"], capture_output=True, text=True)
        pages_free = re.search(r"Pages free:\s+(\d+)", r.stdout)
        if pages_free:
            metrics["ram_free_gb"] = round(int(pages_free.group(1)) * 16384 / (1024**3), 1)
    except:
        pass

    if "metrics" not in persistent:
        persistent["metrics"] = []

    persistent["metrics"].append(metrics)
    persistent["metrics"] = persistent["metrics"][-168:]  # letzte 7 Tage stündlich
    save_state(persistent)

    tps = metrics.get("tokens_per_second", 0)
    ram = metrics.get("ram_free_gb", "?")

    log(f"  📈 tokens/sec: {tps:.1f} | RAM frei: {ram} GB")
    return state

# ── Node 3: Wöchentlicher Report ──────────────────────────────
def generate_weekly_report(state: IntelState) -> IntelState:
    intel = load_intel()
    persistent = load_state()

    last_weekly = intel.get("last_weekly", "")
    now = datetime.now()

    if last_weekly:
        last_dt = datetime.fromisoformat(last_weekly)
        days_since = (now - last_dt).days
        if days_since < 7:
            log(f"  ℹ️ Wochenbericht: letzter vor {days_since} Tagen — noch nicht fällig")
            return state

    log("📋 Erstelle Wochenbericht...")

    # Daten sammeln
    metrics = persistent.get("metrics", [])
    recent_analyses = intel.get("analyses", [])[:20]
    crashes = persistent.get("llama_restarts", [])

    avg_tps = 0
    if metrics:
        tps_values = [m.get("tokens_per_second", 0) for m in metrics if m.get("tokens_per_second")]
        avg_tps = sum(tps_values) / len(tps_values) if tps_values else 0

    relevant_commits = [a for a in recent_analyses if a.get("relevant")]
    high_risk = [a for a in relevant_commits if a.get("risiko") == "hoch"]

    llm = get_llm()
    prompt = f"""Erstelle einen kurzen Wochenbericht für eine lokale KI-Plattform.

DATEN DER LETZTEN WOCHE:
- Durchschnittliche Geschwindigkeit: {avg_tps:.1f} tokens/sec
- LLM-Server Crashes: {len(crashes)}
- Neue relevante TurboQuant Commits: {len(relevant_commits)}
- Davon hohes Risiko: {len(high_risk)}
- Analysierte Commits: {', '.join([a['short_sha'] + ' (' + a['category'] + ')' for a in recent_analyses[:5]])}

Schreibe einen prägnanten Bericht auf Deutsch (max 5 Sätze):
1. Gesamtstatus
2. Performance
3. Wichtigste Änderungen
4. Empfehlung für die nächste Woche"""

    try:
        response = llm.invoke(prompt)
        report = response.content.strip()
        state["weekly_report"] = report

        intel["weekly_reports"].insert(0, {
            "date": now.isoformat(),
            "report": report
        })
        intel["weekly_reports"] = intel["weekly_reports"][:12]
        intel["last_weekly"] = now.isoformat()
        save_intel(intel)

        log(f"  ✅ Wochenbericht erstellt")
        log(f"  {report[:200]}...")
        state["notifications"].append(f"📋 WOCHENBERICHT: {report[:150]}...")
        
        # MemPalace updaten
        try:
            import subprocess
            knowledge_file = Path.home() / "mac-setup/agent/knowledge/decisions.md"
            if knowledge_file.exists():
                existing = knowledge_file.read_text()
                new_entries = []
                for a in intel.get("analyses", [])[:5]:
                    if a.get("relevant") and a.get("short_sha","") not in existing:
                        entry = f"\n## Commit {a.get('short_sha','?')} ({a.get('date','')[:10]})\n- {a.get('auswirkung','')}\n- Empfehlung: {a.get('empfehlung','')}\n"
                        new_entries.append(entry)
                if new_entries:
                    with open(knowledge_file, "a") as kf:
                        kf.write("\n# Auto-Update\n")
                        kf.writelines(new_entries)
                    subprocess.run(["mempalace", "mine", str(knowledge_file.parent), "--wing", "platform"], capture_output=True, timeout=30)
                    log(f"  ✅ MemPalace aktualisiert ({len(new_entries)} Einträge)")
        except Exception as me:
            log(f"  ⚠️ MemPalace: {me}")

    except Exception as e:
        log(f"  ❌ Wochenbericht Fehler: {e}")

    return state

# ── Node 4: Zusammenfassung ────────────────────────────────────
def summarize(state: IntelState) -> IntelState:
    log("🧠 Intelligence Agent Zusammenfassung:")
    if not state["notifications"]:
        log("  ✅ Keine neuen Erkenntnisse")
    for n in state["notifications"]:
        log(f"  {n}")
    log("─" * 60)
    return state

# ── Graph ──────────────────────────────────────────────────────
def build_graph():
    graph = StateGraph(IntelState)

    graph.add_node("analyze_commits", analyze_commits)
    graph.add_node("track_metrics", track_metrics)
    graph.add_node("generate_weekly_report", generate_weekly_report)
    graph.add_node("summarize", summarize)

    graph.set_entry_point("analyze_commits")
    graph.add_edge("analyze_commits", "track_metrics")
    graph.add_edge("track_metrics", "generate_weekly_report")
    graph.add_edge("generate_weekly_report", "summarize")
    graph.add_edge("summarize", END)

    return graph.compile()

if __name__ == "__main__":
    log("=" * 60)
    log("🧠 Intelligence Agent gestartet")
    agent = build_graph()
    result = agent.invoke({
        "commits": [],
        "prs": [],
        "analyses": [],
        "weekly_report": "",
        "notifications": []
    })
    log("🧠 Intelligence Agent beendet")
